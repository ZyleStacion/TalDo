<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" type="text/css" href="css/styles.css">
    <title>TalDo</title>
</head>
<body>
    <!-- Conditional alert rendering -->
     <% if (locals.alert) { %>
      <div class="alert alert-<%=alert.type %>">
        <h2><%=alert.title%></h2>
        <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
      </div>
     <% } %>
    
    <!-- Greeting section -->
    <div class="greeting">
        <h1>Welcome to TalDo</h1>
        <p>Control your digital world - focus on focus.</p>
        <div class="task-count">
            <p><%= tasks.length %> tasks &middot; <%= complete.length %> complete</p>
        </div>
    </div>
    
    <!-- Add task utility -->
    <div class="section-wrapper">
        <form name="add-task" action="/add-task" method="POST" class="add-task">
            <!-- Add task text + button -->
            <div class="input-task">
                <input type="text" id="task" name="task" placeholder="Add a new task...">
                <input type="submit" id="submit" value="Add task">
            </div>

            <!-- Category, priority for tasks -->
            <div class="task-modifiers">
                <label for="category">Category</label>
                <select name="category" id="category">
                    <option>Personal</option>
                    <option>Work</option>
                    <option>School</option>
                    <option>Health</option>
                </select>

                <label for="priority">Priority</label>
                <select name="priority" id="priority">
                    <option>Low</option>
                    <option>Medium</option>
                    <option>High</option>
                </select>
            </div>
        </form>
    </div>

    <!-- Render each task -->
    <div class="task-list">
        <% if (tasks.length === 0) { %>
            <div class="section-wrapper section-wrapper--task">
                <h2>All done for now!</h2>
                <p>Add some tasks to continue being productive.</p>
            </div>
        <% } else { %>
         <% tasks.forEach(item => { %>
            <form class="task-item" action="/complete-task" method="POST">
                <button class="finish-task">Complete</button>
                <p><%= item.task %></p>
                
                <div class="task-tags">
                    <!-- TODO: Make these filter the current task layout -->
                    <a class="category-<%= item.category %>"><%= item.category %></a>
                    <a class="priority-<%= item.priority %>"><%= item.priority %></a>
                </div>
                
                <div class="utility-buttons">
                    <button>Edit Task</button>
                    <button formaction="/delete-task">Delete Task</button>
                </div>
            </form>
         <% }); %>
        <% } %>
    </div>
</body>
</html>